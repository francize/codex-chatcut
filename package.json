  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "stage:plugin": "node scripts/stage-local-plugin.mjs",
    "validate:plugin": "node scripts/stage-local-plugin.mjs --check",
    "typecheck": "tsc --noEmit",
