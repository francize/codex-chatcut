@@ -0,0 +1,157 @@
+import { createHash, randomBytes, timingSafeEqual } from 'node:crypto';
+import type { IncomingMessage, ServerResponse } from 'node:http';
+
+const BROWSER_COOKIE = 'openchatcut_browser_capability';
+const DEFAULT_CAPABILITY_TTL_MS = 15 * 60 * 1_000;
+const MAX_ACTIVE_CAPABILITIES = 16;
+
+export interface AuthorizationSuccess {
+  ok: true;
+}
+
+export interface AuthorizationFailure {
+  ok: false;
+  status: 401 | 403 | 503;
+  error: string;
+}
+
+export type Authorization = AuthorizationSuccess | AuthorizationFailure;
+
+export interface ExternalAgentSecurityOptions {
+  mcpCredential?: string;
+  browserCredential?: string;
+  capabilityTtlMs?: number;
+}
+
+function header(value: string | string[] | undefined): string | null {
+  return typeof value === 'string' ? value : null;
+}
+
+function equalSecret(actual: string | null, expected: string): boolean {
+  if (!actual) return false;
+  const actualBytes = Buffer.from(actual);
+  const expectedBytes = Buffer.from(expected);
+  return actualBytes.length === expectedBytes.length && timingSafeEqual(actualBytes, expectedBytes);
+}
+
+function capabilityDigest(value: string): string {
+  return createHash('sha256').update(value).digest('base64url');
+}
+
+function cookieValue(req: IncomingMessage, name: string): string | null {
+  const cookies = header(req.headers.cookie);
+  if (!cookies) return null;
+  for (const pair of cookies.split(';')) {
+    const separator = pair.indexOf('=');
+    if (separator < 0 || pair.slice(0, separator).trim() !== name) continue;
+    return pair.slice(separator + 1).trim() || null;
+  }
+  return null;
+}
+
+function forbidden(error: string): AuthorizationFailure {
+  return { ok: false, status: 403, error };
+}
+
+export class ExternalAgentSecurity {
+  private readonly mcpCredential: string;
+  private readonly browserCredential: string;
+  private readonly capabilityTtlMs: number;
+  private readonly browserCapabilities = new Map<string, number>();
+
+  constructor(options: ExternalAgentSecurityOptions = {}) {
+    this.mcpCredential = options.mcpCredential?.trim()
+      ?? process.env.OPENCHATCUT_MCP_TOKEN?.trim()
+      ?? '';
+    this.browserCredential = options.browserCredential?.trim()
+      || process.env.OPENCHATCUT_BROWSER_TOKEN?.trim()
+      || randomBytes(32).toString('base64url');
+    if (this.mcpCredential && equalSecret(this.browserCredential, this.mcpCredential)) {
+      throw new Error('OpenChatCut MCP and browser credentials must be different');
+    }
+    this.capabilityTtlMs = Math.max(1_000, options.capabilityTtlMs ?? DEFAULT_CAPABILITY_TTL_MS);
+  }
+
+  loopbackOrigin(req: IncomingMessage): string | null {
+    const { localAddress, localPort } = req.socket;
+    if (localAddress !== '127.0.0.1' || !Number.isInteger(localPort) || !localPort) return null;
+    return `http://127.0.0.1:${localPort}`;
+  }
+
+  private requestBoundary(req: IncomingMessage, browser: boolean): Authorization {
+    const expectedOrigin = this.loopbackOrigin(req);
+    if (!expectedOrigin) return forbidden('OpenChatCut bridge accepts loopback requests only');
+    const expectedHost = new URL(expectedOrigin).host;
+    if (header(req.headers.host) !== expectedHost) {
+      return forbidden('invalid OpenChatCut bridge Host');
+    }
+
+    const origin = header(req.headers.origin);
+    const fetchSite = header(req.headers['sec-fetch-site']);
+    if (browser) {
+      if (origin !== expectedOrigin) return forbidden('invalid OpenChatCut bridge Origin');
+      if (fetchSite !== 'same-origin') return forbidden('invalid OpenChatCut bridge fetch site');
+    } else {
+      if (origin !== null && origin !== expectedOrigin) {
+        return forbidden('invalid OpenChatCut bridge Origin');
+      }
+      if (fetchSite !== null && fetchSite !== 'same-origin') {
+        return forbidden('invalid OpenChatCut bridge fetch site');
+      }
+    }
+    return { ok: true };
+  }
+
+  authorizeMcp(req: IncomingMessage): Authorization {
+    const boundary = this.requestBoundary(req, false);
+    if (!boundary.ok) return boundary;
+    if (!this.mcpCredential) {
+      return { ok: false, status: 503, error: 'OpenChatCut MCP credential is not configured' };
+    }
+    const authorization = header(req.headers.authorization);
+    const supplied = authorization?.startsWith('Bearer ') ? authorization.slice(7) : null;
+    if (!equalSecret(supplied, this.mcpCredential)) {
+      return { ok: false, status: 401, error: 'invalid OpenChatCut MCP credential' };
+    }
+    return { ok: true };
+  }
+
+  authorizeBrowser(req: IncomingMessage): Authorization {
+    const boundary = this.requestBoundary(req, true);
+    if (!boundary.ok) return boundary;
+    this.removeExpiredCapabilities();
+    const capability = cookieValue(req, BROWSER_COOKIE);
+    const expiresAt = capability ? this.browserCapabilities.get(capabilityDigest(capability)) : undefined;
+    if (!expiresAt || expiresAt <= Date.now()) {
+      return { ok: false, status: 401, error: 'invalid OpenChatCut browser capability' };
+    }
+    return { ok: true };
+  }
+
+  issueBrowserCapability(req: IncomingMessage, res: ServerResponse): Authorization {
+    const boundary = this.requestBoundary(req, true);
+    if (!boundary.ok) return boundary;
+    this.removeExpiredCapabilities();
+    while (this.browserCapabilities.size >= MAX_ACTIVE_CAPABILITIES) {
+      const oldest = this.browserCapabilities.keys().next().value as string | undefined;
+      if (!oldest) break;
+      this.browserCapabilities.delete(oldest);
+    }
+
+    const capability = this.browserCredential;
+    this.browserCapabilities.set(capabilityDigest(capability), Date.now() + this.capabilityTtlMs);
+    const maxAge = Math.max(1, Math.floor(this.capabilityTtlMs / 1_000));
+    res.setHeader(
+      'Set-Cookie',
+      `${BROWSER_COOKIE}=${capability}; HttpOnly; SameSite=Strict; Path=/api/external-agent; Max-Age=${maxAge}`,
+    );
+    return { ok: true };
+  }
+
+  private removeExpiredCapabilities(): void {
+    const now = Date.now();
+    for (const [digest, expiresAt] of this.browserCapabilities) {
+      if (expiresAt <= now) this.browserCapabilities.delete(digest);
+    }
+  }
+}
