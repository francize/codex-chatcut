+/**
+ * Protect every embedded-server route before key-injecting proxies or upstream
+ * plugins run. MCP bearer routes and control-only tool discovery retain their
+ * narrower authorization handlers. The credential-free editor document is the
+ * only route that may create an initial HttpOnly browser capability; bootstrap
+ * can renew it only after this middleware validates the existing cookie.
+ */
+export function embeddedBrowserSecurityMiddleware(
+  security: ExternalAgentSecurity,
+): EmbeddedSecurityMiddleware {
+  return (req, res, next) => {
+    res.setHeader('Cross-Origin-Opener-Policy', 'same-origin');
+    res.setHeader('Content-Security-Policy', "frame-ancestors 'none'");
+    res.setHeader('Referrer-Policy', 'no-referrer');
+    res.setHeader('X-Content-Type-Options', 'nosniff');
+    res.setHeader('X-Frame-Options', 'DENY');
+
+    const loopback = security.authorizeLoopbackHost(req);
+    if (sendAuthorizationFailure(res, loopback)) return;
+
+    const requestUrl = new URL(req.url ?? '/', 'http://localhost');
+    const path = requestUrl.pathname;
+    if (
+      path === '/api/external-mcp/mcp'
+      || path === '/api/external-agent/tools'
+    ) {
+      next();
+      return;
+    }
+    if (path === '/' || path === '/index.html') {
+      const navigation = security.issueNavigationCapability(req, res);
+      if (!navigation.ok) {
+        const existing = security.authorizeBrowserRead(req);
+        if (sendAuthorizationFailure(res, existing)) return;
+      }
+      if (requestUrl.searchParams.get('host') !== 'codex') {
+        requestUrl.searchParams.set('host', 'codex');
+        res.statusCode = 307;
+        res.setHeader('Location', `${path}${requestUrl.search}`);
+        res.setHeader('Cache-Control', 'no-store');
+        res.end();
+        return;
+      }
+      next();
+      return;
+    }
+
+    const authorization = req.method === 'GET' || req.method === 'HEAD'
+      ? security.authorizeBrowserRead(req)
+      : security.authorizeBrowser(req);
+    if (sendAuthorizationFailure(res, authorization)) return;
+    next();
+  };
+}
