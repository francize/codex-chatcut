+/** Build the editor link returned by the external MCP control tools. */
+export function externalEditorUrl(
+  args: Record<string, unknown>,
+  projectId: string,
+  fallbackBase: string,
+  hostMode = process.env.OPENCHATCUT_HOST_MODE?.trim(),
+): string {
+  const codexHost = hostMode === 'codex';
+  const requestedBase = String(args.editorBaseUrl ?? '').trim();
+  // In Codex Host Mode the authenticated sidecar origin is authoritative. Do
+  // not let an MCP argument turn the Browser handoff into an external URL.
+  const base = (codexHost ? fallbackBase : requestedBase || fallbackBase).replace(/\/+$/, '');
+  const hostQuery = codexHost ? '?host=codex' : '';
+  return `${base}/${hostQuery}#/editor/${encodeURIComponent(projectId)}`;
+}
