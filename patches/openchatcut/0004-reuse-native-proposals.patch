diff --git a/src/agent/externalToolExecutor.ts b/src/agent/externalToolExecutor.ts
new file mode 100644
index 0000000..5f80f57
--- /dev/null
+++ b/src/agent/externalToolExecutor.ts
@@ -0,0 +1,105 @@
+import type { AgentContext } from './context';
+import type { ProposalController } from './proposalController';
+import type { AgentToolSchema } from './tool-schema';
+import type { ProjectDoc } from '../editor/types';
+
+export const CODEX_PROPOSAL_TOOL_SCHEMAS: AgentToolSchema[] = [
+  {
+    name: 'get_chatcut_context',
+    description: 'Read the mounted OpenChatCut project and pending native edit proposal without changing either.',
+    input_schema: { type: 'object', properties: {} },
+  },
+  {
+    name: 'get_chatcut_proposal',
+    description: 'Read the pending OpenChatCut native proposal, including its original tool ids and reducer actions.',
+    input_schema: { type: 'object', properties: {} },
+  },
+  {
+    name: 'apply_chatcut_proposal',
+    description: 'Apply the pending OpenChatCut proposal atomically as one native undo step. Fails if the project changed.',
+    input_schema: { type: 'object', properties: {} },
+  },
+  {
+    name: 'reject_chatcut_proposal',
+    description: 'Reject the pending OpenChatCut proposal without changing the project.',
+    input_schema: { type: 'object', properties: {} },
+  },
+  {
+    name: 'undo_chatcut_edit',
+    description: 'Undo one edit through the mounted OpenChatCut editor history and persist the restored project.',
+    input_schema: { type: 'object', properties: {} },
+  },
+];
+
+export interface ExternalToolExecutionDependencies {
+  executeTool: (name: string, args: Record<string, unknown>, ctx: AgentContext) => Promise<unknown>;
+  afterCommit: () => Promise<void>;
+  saveProject: (projectId: string, doc: ProjectDoc) => Promise<void>;
+}
+
+interface ExternalToolExecutionOptions {
+  name: string;
+  args: Record<string, unknown>;
+  context: AgentContext;
+  projectId: string;
+  codexHost: boolean;
+  nativeToolNames: ReadonlySet<string>;
+  proposalController: ProposalController;
+  dependencies: ExternalToolExecutionDependencies;
+}
+
+const controlToolNames = new Set(CODEX_PROPOSAL_TOOL_SCHEMAS.map((tool) => tool.name));
+
+/** Select host integration behavior without duplicating any editor operation. */
+export async function executeExternalTool(options: ExternalToolExecutionOptions): Promise<unknown> {
+  const {
+    name,
+    args,
+    context,
+    projectId,
+    codexHost,
+    nativeToolNames,
+    proposalController,
+    dependencies,
+  } = options;
+
+  if (!codexHost) {
+    if (!nativeToolNames.has(name)) throw new Error(`unknown OpenChatCut tool ${name}`);
+    const result = await dependencies.executeTool(name, args, context);
+    await dependencies.afterCommit();
+    await dependencies.saveProject(projectId, context.getDoc());
+    return result;
+  }
+
+  // The React hydration effect is not an ordering boundary for external MCP
+  // calls. Every Codex read or mutation observes the persisted proposal first.
+  await proposalController.hydrate();
+
+  if (name === 'get_chatcut_context') {
+    proposalController.refreshStale();
+    const state = proposalController.getState();
+    return {
+      projectId,
+      projectDoc: context.getDoc(),
+      pendingProposal: state.proposal,
+      proposalStale: state.stale,
+    };
+  }
+  if (name === 'get_chatcut_proposal') {
+    proposalController.refreshStale();
+    return { projectId, ...proposalController.getState() };
+  }
+  if (name === 'apply_chatcut_proposal') {
+    const result = await proposalController.apply();
+    if (result.status === 'stale') {
+      throw new Error('OpenChatCut proposal is stale; reject it and propose against the current project');
+    }
+    return result;
+  }
+  if (name === 'reject_chatcut_proposal') return proposalController.reject();
+  if (name === 'undo_chatcut_edit') return proposalController.undo();
+  if (controlToolNames.has(name) || !nativeToolNames.has(name)) {
+    throw new Error(`unknown OpenChatCut tool ${name}`);
+  }
+  return proposalController.executeNative(name, args);
+}
diff --git a/src/agent/proposalController.ts b/src/agent/proposalController.ts
new file mode 100644
index 0000000..fc03f81
--- /dev/null
+++ b/src/agent/proposalController.ts
@@ -0,0 +1,263 @@
+import type { AgentContext } from './context';
+import type { Operation, Proposal } from './proposal';
+import type { AnyAction, DraftEngine } from '../editor/store';
+import type { ProjectDoc, TimelineState } from '../editor/types';
+
+export interface ProposalControllerState {
+  proposal: Proposal | null;
+  stale: boolean;
+  hydrated: boolean;
+}
+
+export interface ProposalControllerDependencies {
+  makeDraft: (base: ProjectDoc) => DraftEngine;
+  executeTool: (name: string, args: Record<string, unknown>, ctx: AgentContext) => Promise<unknown>;
+  buildOperation: (tool: string, args: Record<string, unknown>, actions: AnyAction[]) => Operation;
+  buildProposal: (
+    operations: Operation[],
+    assistantText: string,
+    baseDoc: ProjectDoc,
+    resultState: TimelineState,
+  ) => Proposal;
+  isProposalStale: (proposal: Proposal, currentDoc: ProjectDoc) => boolean;
+  partitionProposalActions: (actions: AnyAction[]) => {
+    persistent: AnyAction[];
+    proposed: AnyAction[];
+  };
+  replayActions: (base: ProjectDoc, actions: AnyAction[]) => ProjectDoc;
+  loadProposal: (projectId: string) => Promise<Proposal | null>;
+  saveProposal: (projectId: string, proposal: Proposal) => Promise<void>;
+  clearProposal: (projectId: string) => Promise<void>;
+  saveProject: (projectId: string, doc: ProjectDoc) => Promise<void>;
+  afterCommit: () => Promise<void>;
+}
+
+interface ProposalControllerOptions {
+  projectId: string;
+  getContext: () => AgentContext;
+  dependencies: ProposalControllerDependencies;
+}
+
+export interface ProposalDraftResult {
+  proposal: Proposal | null;
+  invalidated: boolean;
+  operationCount: number;
+}
+
+export interface ProposalDraftRun {
+  context: AgentContext;
+  recordTool: (name: string, args: Record<string, unknown>) => void;
+  finish: (assistantText: string, options?: { publish?: boolean }) => Promise<ProposalDraftResult>;
+}
+
+export type ProposalApplyResult =
+  | { status: 'applied'; projectId: string; operations: number }
+  | { status: 'stale'; projectId: string };
+
+export interface ProposalApplyOptions {
+  force?: boolean;
+  /** Runs after the live atomic apply, before proposal-boundary subscribers persist chat. */
+  onApplied?: (result: Extract<ProposalApplyResult, { status: 'applied' }>) => void;
+}
+
+/**
+ * The single proposal lifecycle shared by OpenChatCut's own ChatPanel agent and
+ * Codex Host Mode. Domain mutations remain owned by the injected upstream
+ * draft, action, reducer, persistence, and EditorCommands primitives.
+ */
+export class ProposalController {
+  private readonly projectId: string;
+  private readonly getContext: () => AgentContext;
+  private readonly dependencies: ProposalControllerDependencies;
+  private readonly listeners = new Set<(state: ProposalControllerState) => void>();
+  private state: ProposalControllerState = { proposal: null, stale: false, hydrated: false };
+  private hydration: Promise<ProposalControllerState> | null = null;
+
+  constructor(options: ProposalControllerOptions) {
+    this.projectId = options.projectId;
+    this.getContext = options.getContext;
+    this.dependencies = options.dependencies;
+  }
+
+  getState(): ProposalControllerState {
+    return this.state;
+  }
+
+  subscribe(listener: (state: ProposalControllerState) => void): () => void {
+    this.listeners.add(listener);
+    listener(this.state);
+    return () => this.listeners.delete(listener);
+  }
+
+  hydrate(): Promise<ProposalControllerState> {
+    this.hydration ??= this.hydrateOnce();
+    return this.hydration;
+  }
+
+  refreshStale(): void {
+    const stale = this.state.proposal
+      ? this.dependencies.isProposalStale(this.state.proposal, this.getContext().getDoc())
+      : false;
+    if (stale === this.state.stale) return;
+    this.setState({ ...this.state, stale });
+  }
+
+  beginDraft(): ProposalDraftRun {
+    if (this.state.proposal) {
+      throw new Error('resolve the pending OpenChatCut proposal before starting another edit');
+    }
+    const baseDoc = this.getContext().getDoc();
+    const draft = this.dependencies.makeDraft(baseDoc);
+    const draftContext: AgentContext = {
+      ...this.getContext(),
+      commands: draft.commands,
+      getState: draft.getState,
+      getDoc: draft.getDoc,
+    };
+    const operations: Operation[] = [];
+    let persistence = Promise.resolve();
+    let proposalBaseDoc = baseDoc;
+    let invalidated = false;
+    let finished = false;
+
+    return {
+      context: draftContext,
+      recordTool: (name, args) => {
+        if (finished) throw new Error('OpenChatCut proposal draft is already finished');
+        const actions = draft.takeActions();
+        const { persistent, proposed } = this.dependencies.partitionProposalActions(actions);
+        const observed = this.getContext().getDoc();
+        if (observed !== baseDoc && observed !== proposalBaseDoc) {
+          invalidated = true;
+          proposalBaseDoc = observed;
+        }
+        if (persistent.length) {
+          proposalBaseDoc = this.dependencies.replayActions(proposalBaseDoc, persistent);
+          this.getContext().commands.applyDoc(proposalBaseDoc);
+          const projectSnapshot = proposalBaseDoc;
+          persistence = persistence.then(() => (
+            this.dependencies.saveProject(this.projectId, projectSnapshot)
+          ));
+        }
+        if (proposed.length) {
+          operations.push(this.dependencies.buildOperation(name, args, proposed));
+        }
+      },
+      finish: async (assistantText, options = {}) => {
+        if (finished) throw new Error('OpenChatCut proposal draft is already finished');
+        finished = true;
+        await persistence;
+        const publish = options.publish ?? true;
+        if (!publish || invalidated || !operations.length) {
+          return { proposal: null, invalidated, operationCount: operations.length };
+        }
+        const proposal = this.dependencies.buildProposal(
+          operations,
+          assistantText,
+          proposalBaseDoc,
+          draft.getState(),
+        );
+        await this.publish(proposal);
+        return { proposal, invalidated: false, operationCount: operations.length };
+      },
+    };
+  }
+
+  async executeNative(name: string, args: Record<string, unknown>): Promise<unknown> {
+    await this.hydrate();
+    const run = this.beginDraft();
+    const result = await this.dependencies.executeTool(name, args, run.context);
+    run.recordTool(name, args);
+    const outcome = await run.finish(`OpenChatCut ${name}`);
+    if (outcome.invalidated) {
+      throw new Error('OpenChatCut project changed while the native tool was running; persistent assets were saved, retry the edit');
+    }
+    if (!outcome.proposal) return result;
+    return {
+      status: 'proposal_pending',
+      projectId: this.projectId,
+      result,
+      proposal: outcome.proposal,
+    };
+  }
+
+  async apply(selected?: ReadonlySet<number>, options: ProposalApplyOptions = {}): Promise<ProposalApplyResult> {
+    await this.hydrate();
+    const proposal = this.state.proposal;
+    if (!proposal) throw new Error('no pending OpenChatCut proposal');
+    const context = this.getContext();
+    const currentDoc = context.getDoc();
+    if (!options.force && this.dependencies.isProposalStale(proposal, currentDoc)) {
+      this.setState({ ...this.state, stale: true });
+      return { status: 'stale', projectId: this.projectId };
+    }
+    const operations = proposal.options[0].operations.filter((_, index) => (
+      selected ? selected.has(index) : true
+    ));
+    if (!operations.length) throw new Error('no OpenChatCut proposal operations selected');
+    const nextDoc = this.dependencies.replayActions(
+      currentDoc,
+      operations.flatMap((operation) => operation.actions),
+    );
+    context.commands.applyDoc(nextDoc);
+    const result = {
+      status: 'applied' as const,
+      projectId: this.projectId,
+      operations: operations.length,
+    };
+    options.onApplied?.(result);
+    this.setState({ proposal: null, stale: false, hydrated: true });
+    await Promise.all([
+      this.dependencies.saveProject(this.projectId, nextDoc),
+      this.dependencies.clearProposal(this.projectId),
+    ]);
+    return result;
+  }
+
+  async reject(): Promise<{ status: 'rejected'; projectId: string }> {
+    await this.hydrate();
+    if (!this.state.proposal) throw new Error('no pending OpenChatCut proposal');
+    this.setState({ proposal: null, stale: false, hydrated: true });
+    await this.dependencies.clearProposal(this.projectId);
+    return { status: 'rejected', projectId: this.projectId };
+  }
+
+  async clear(): Promise<void> {
+    this.setState({ proposal: null, stale: false, hydrated: true });
+    await this.dependencies.clearProposal(this.projectId);
+  }
+
+  async undo(): Promise<{ status: 'undone'; projectId: string }> {
+    this.getContext().commands.undo();
+    await this.dependencies.afterCommit();
+    const restored = this.getContext().getDoc();
+    await this.dependencies.saveProject(this.projectId, restored);
+    this.refreshStale();
+    return { status: 'undone', projectId: this.projectId };
+  }
+
+  private async hydrateOnce(): Promise<ProposalControllerState> {
+    const pending = await this.dependencies.loadProposal(this.projectId);
+    // Any completed in-memory mutation (publish/apply/reject/clear) is newer
+    // than the storage read that was already in flight. In particular, a
+    // late load must never resurrect a proposal cleared during hydration.
+    if (this.state.hydrated) return this.state;
+    if (pending && !this.dependencies.isProposalStale(pending, this.getContext().getDoc())) {
+      this.setState({ proposal: pending, stale: false, hydrated: true });
+    } else {
+      this.setState({ proposal: null, stale: false, hydrated: true });
+      if (pending) await this.dependencies.clearProposal(this.projectId);
+    }
+    return this.state;
+  }
+
+  private async publish(proposal: Proposal): Promise<void> {
+    this.setState({ proposal, stale: false, hydrated: true });
+    await this.dependencies.saveProposal(this.projectId, proposal);
+  }
+
+  private setState(state: ProposalControllerState): void {
+    this.state = state;
+    for (const listener of this.listeners) listener(state);
+  }
+}
diff --git a/src/agent/proposalControllerRuntime.ts b/src/agent/proposalControllerRuntime.ts
new file mode 100644
index 0000000..10bd88e
--- /dev/null
+++ b/src/agent/proposalControllerRuntime.ts
@@ -0,0 +1,36 @@
+import type { AgentContext } from './context';
+import { ProposalController } from './proposalController';
+import {
+  buildOperation,
+  buildProposal,
+  isProposalStale,
+  partitionProposalActions,
+} from './proposal';
+import { executeTool } from './tools';
+import { makeDraft, replayActions } from '../editor/store';
+import { saveProject } from '../persist/projectStore';
+import { clearProposal, loadProposal, saveProposal } from '../persist/proposalStore';
+
+const afterCommit = () => new Promise<void>((resolve) => requestAnimationFrame(() => resolve()));
+
+const dependencies = {
+  makeDraft,
+  executeTool,
+  buildOperation,
+  buildProposal,
+  isProposalStale,
+  partitionProposalActions,
+  replayActions,
+  loadProposal,
+  saveProposal,
+  clearProposal,
+  saveProject,
+  afterCommit,
+};
+
+export function createProposalController(
+  projectId: string,
+  getContext: () => AgentContext,
+): ProposalController {
+  return new ProposalController({ projectId, getContext, dependencies });
+}
